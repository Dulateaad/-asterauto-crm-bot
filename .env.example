# PostgreSQL (VPS). Пример: postgresql://asterbot:ПАРОЛЬ@127.0.0.1:5432/asterauto_bot
DATABASE_URL=

# BotFather
TELEGRAM_BOT_TOKEN=

# Кто может /adduser — Telegram user id через запятую
BOT_ADMIN_IDS=

# Опционально: секрет webhook (A-Za-z0-9_-), от 8 символов
# BOT_WEBHOOK_SECRET=

# РОП — уведомления о SLA 30 мин (telegram id через запятую)
ROP_TELEGRAM_IDS=

# Отдел для сводки РОП: одинаковый departmentId у РОП и менеджеров; админ: /setdept <tg> <slug>
SLA_REMINDER_MINUTES=15
SLA_ROP_MINUTES=30

# Опрос покупателя после заявки из Telegram (минуты)
CUSTOMER_SURVEY_MINUTES=15

# Интервал фоновых задач (SLA + опрос покупателя), мс
# BOT_POLLER_INTERVAL_MS=120000
# Временно выключить фоновые опросы: true или 1
# BOT_DISABLE_BACKGROUND_POLL=1
