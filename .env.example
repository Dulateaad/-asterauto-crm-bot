# Firebase — тот же проект, что и веб (сейчас по умолчанию asterauto-d8e74)
FIREBASE_PROJECT_ID=asterauto-d8e74

# Сервисный аккаунт (JSON скачать из Firebase Console → Project settings → Service accounts)
# Локально — путь к файлу:
GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json

# На VPS / Render — либо вся JSON одной строкой, либо base64 файла (надёжнее для Render):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=<base64 -w0 serviceAccount.json>

# BotFather
TELEGRAM_BOT_TOKEN=

# Кто может /adduser — Telegram user id через запятую
BOT_ADMIN_IDS=

# Опционально: секрет webhook (A-Za-z0-9_-), от 8 символов
# BOT_WEBHOOK_SECRET=

# РОП — уведомления о SLA 30 мин (telegram id через запятую)
ROP_TELEGRAM_IDS=

# Отдел для сводки РОП: одинаковый departmentId в Firestore у РОП и менеджеров; админ: /setdept <tg> <slug>
SLA_ROP_MINUTES=30
